as.data.frame() %>%
dplyr::rename(thing = 1) %>%
group_by(thing) %>%
mutate(Marker = str_split(thing, " ")[[1]][1],
p = as.numeric(str_split(thing, " ")[[1]][2]),
p23 = p*(2/3) / 100) %>%
ungroup() %>%
select(!thing)
